<% content_for :title, "My configs — alirokeys" %>
<div class="page">
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="text-2xl font-bold tracking-tight text-slate-900">My configs</h1>
      <p class="mt-1 text-sm text-slate-500">Configs you’ve created. Only you can edit or delete them.</p>
    </div>
    <%= link_to new_aliro_config_path, class: "btn-primary" do %>
      <%= icon(:plus) %> New config
    <% end %>
  </div>

  <div class="card overflow-hidden">
    <% @configs.each do |config| %>
      <div class="flex flex-wrap items-center gap-4 border-b border-slate-100 px-5 py-4 last:border-0">
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2">
            <span class="font-semibold text-slate-900"><%= config.name %></span>
            <%= config.is_sample ? tag.span("sample", class: "badge-sample") : tag.span("private", class: "badge-private") %>
          </div>
          <p class="mt-0.5 truncate font-mono text-xs text-slate-500"><%= config.domain %> · <%= config.reader_group_id %></p>
        </div>

        <div class="flex items-center gap-2">
          <% if config.is_sample %>
            <%= link_to "View", sample_config_path(config.domain, config), class: "btn-ghost btn-sm" %>
          <% end %>
          <%= link_to "Edit", edit_aliro_config_path(config), class: "btn-ghost btn-sm" %>
          <%= button_to "Share", aliro_config_share_path(config), class: "btn-secondary btn-sm" %>
          <%= button_to "Delete", aliro_config_path(config), method: :delete, class: "btn-danger btn-sm",
                form: { data: { turbo_confirm: "Delete “#{config.name}”? This cannot be undone." } } %>
        </div>
      </div>
    <% end %>
  </div>
</div>
