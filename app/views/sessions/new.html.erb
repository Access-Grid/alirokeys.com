<% content_for :title, "Sign in — alirokeys" %>
<div class="page-narrow">
  <div class="card-pad">
    <div class="text-center">
      <span class="mx-auto flex h-12 w-12 items-center justify-center rounded-xl bg-brand-50 text-brand-600"><%= icon(:key, classes: "h-6 w-6") %></span>
      <h1 class="mt-4 text-2xl font-bold tracking-tight text-slate-900">Sign in</h1>
      <p class="mt-2 text-sm text-slate-600">
        We’ll email you a one-time magic link. No password required.
      </p>
    </div>

    <%= form_with url: magic_link_path, method: :post, class: "mt-6 space-y-4" do %>
      <div>
        <%= label_tag :email, "Work email", class: "label" %>
        <%= email_field_tag :email, @email, placeholder: "you@yourcompany.com", class: "input mt-1", required: true %>
        <p class="hint">Organization emails only — free-mail providers (gmail, outlook, …) aren’t accepted.</p>
      </div>
      <%= submit_tag "Send magic link", class: "btn-primary w-full" %>
    <% end %>
  </div>

  <p class="mt-6 text-center text-sm text-slate-500">
    Sessions are short-lived by design. You’ll re-authenticate often.
  </p>
</div>
