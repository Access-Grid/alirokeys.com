<% content_for :title, "New config — alirokeys" %>
<div class="page-narrow">
  <h1 class="text-2xl font-bold tracking-tight text-slate-900">Add a config</h1>
  <p class="mt-1 text-sm text-slate-500">Paste your reader key material — we validate it before it’s saved.</p>

  <div class="card-pad mt-6">
    <%= render "form", url: aliro_configs_path, method: :post, config: nil,
          submit_label: "Create config", show_errors: @show_errors %>
  </div>

  <% unless @show_errors %>
    <p class="mt-4 text-center text-xs text-slate-400">
      <%= link_to "Preview the validation-error state", new_aliro_config_path(errors: 1), class: "font-medium" %>
    </p>
  <% end %>
</div>
