<%# locals: config (an AliroConfig) %>
<%= form_with model: config, class: "space-y-6" do |f| %>
  <% if config.errors.any? %>
    <div class="rounded-lg bg-red-50 p-4 text-sm text-red-800 ring-1 ring-inset ring-red-600/20">
      <p class="font-semibold"><%= pluralize(config.errors.count, "error") %> stopped this from saving</p>
      <ul class="mt-1 list-disc pl-5">
        <% config.errors.full_messages.each do |m| %><li><%= m %></li><% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :name, "Name", class: "label" %>
    <%= f.text_field :name, class: "input mt-1", placeholder: "Front Door Reader" %>
  </div>

  <div>
    <span class="label">Domain</span>
    <div class="input mt-1 flex items-center gap-2 bg-slate-50 text-slate-600">
      <span class="font-mono"><%= config.domain_name %></span>
      <span class="badge-neutral">from your account</span>
    </div>
    <p class="hint">Configs are published under your account's domain.</p>
  </div>

  <div>
    <%= f.label :reader_group_id, "Reader group ID", class: "label" %>
    <%= f.text_field :reader_group_id, class: "input-mono mt-1 #{'input-error' if config.errors[:reader_group_id].any?}",
          placeholder: "16 bytes — hex or base64" %>
    <% if config.errors[:reader_group_id].any? %>
      <p class="field-error"><%= config.errors[:reader_group_id].first %></p>
    <% else %>
      <p class="hint">16 bytes. Hex (32 chars) or base64. e.g. <code>17cb8ab0dcd640f3a03cfa2aae7a5775</code></p>
    <% end %>
  </div>

  <div>
    <%= f.label :reader_public_key, "Reader public key", class: "label" %>
    <%= f.text_area :reader_public_key, rows: 3,
          class: "input-mono mt-1 #{'input-error' if config.errors[:reader_public_key].any?}",
          placeholder: "65 bytes — uncompressed P-256, starts with 04" %>
    <% if config.errors[:reader_public_key].any? %>
      <p class="field-error"><%= config.errors[:reader_public_key].first %></p>
    <% else %>
      <p class="hint">65 bytes, uncompressed (starts with <code>04</code>). Hex (130 chars) or base64. Validated on-curve.</p>
    <% end %>
  </div>

  <div>
    <%= f.label :reader_certificate, "Reader certificate", class: "label" %>
    <span class="text-xs text-slate-400">— optional</span>
    <%= f.text_area :reader_certificate, rows: 3,
          class: "input-mono mt-1 #{'input-error' if config.errors[:reader_certificate].any?}",
          placeholder: "Aliro reader certificate (hex or base64)" %>
    <% if config.errors[:reader_certificate].any? %>
      <p class="field-error"><%= config.errors[:reader_certificate].first %></p>
    <% else %>
      <p class="hint">If present, its embedded public key must match the reader public key.</p>
    <% end %>
  </div>

  <label class="flex items-center gap-3">
    <%= f.check_box :is_sample, class: "h-4 w-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" %>
    <span class="text-sm text-slate-700">List publicly as a <span class="font-medium">sample</span> on the domain profile</span>
  </label>

  <div class="flex items-center gap-3 border-t border-slate-100 pt-5">
    <%= f.submit (config.persisted? ? "Save changes" : "Create config"), class: "btn-primary" %>
    <%= link_to "Cancel", dashboard_path, class: "btn-ghost" %>
  </div>
<% end %>
