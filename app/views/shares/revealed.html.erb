<% content_for :title, "Config retrieved — alirokeys" %>
<div class="page">
  <div class="mx-auto max-w-3xl">
    <div class="mb-6 rounded-lg bg-emerald-50 p-4 text-sm font-medium text-emerald-800 ring-1 ring-inset ring-emerald-600/20">
      Config retrieved. It has now been destroyed — this link won’t work again. Save what you need below.
    </div>

    <h1 class="text-2xl font-bold tracking-tight text-slate-900"><%= @config.name %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= @config.domain_name %></p>

    <div class="mt-6 space-y-4">
      <%= render "configs/key_field", field: "Reader group ID", hex: @config.reader_group_id %>
      <%= render "configs/key_field", field: "Reader public key", hex: @config.reader_public_key %>
      <% if @config.cert? %>
        <%= render "configs/key_field", field: "Reader certificate", hex: @config.reader_certificate %>
      <% end %>
      <%= render "configs/export", config: @config %>
    </div>
  </div>
</div>
