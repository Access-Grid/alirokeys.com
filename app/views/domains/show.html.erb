<% content_for :title, "#{@domain} — Aliro Keys" %>
<div class="page">
  <header class="border-b border-slate-200 pb-6">
    <p class="text-sm font-medium text-slate-500">Domain profile</p>
    <h1 class="mt-1 text-3xl font-bold tracking-tight text-slate-900"><%= @domain %></h1>
    <p class="mt-2 text-sm text-slate-500"><%= pluralize(@configs.size, "public sample config") %></p>
  </header>

  <% if @configs.any? %>
    <div class="card mt-6 overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200 text-left text-xs font-medium uppercase tracking-wide text-slate-400">
            <th class="px-5 py-3">Name</th>
            <th class="px-5 py-3">Reader group ID</th>
            <th class="hidden px-5 py-3 lg:table-cell">Public key</th>
            <th class="px-5 py-3">Cert</th>
            <th class="px-5 py-3"></th>
          </tr>
        </thead>
        <tbody>
          <% @configs.each do |config| %>
            <tr class="border-b border-slate-100 last:border-0 hover:bg-slate-50">
              <td class="px-5 py-3 font-medium text-slate-900">
                <%= link_to config.name, sample_config_path(config.domain_name, config), class: "hover:text-brand-700" %>
              </td>
              <td class="px-5 py-3 font-mono text-xs text-slate-600"><%= config.reader_group_id %></td>
              <td class="hidden px-5 py-3 lg:table-cell">
                <span class="block max-w-[18rem] truncate font-mono text-xs text-slate-500"><%= config.reader_public_key %></span>
              </td>
              <td class="px-5 py-3">
                <%= config.cert? ? tag.span("yes", class: "badge-neutral") : tag.span("—", class: "text-slate-400") %>
              </td>
              <td class="px-5 py-3 text-right">
                <%= link_to "View →", sample_config_path(config.domain_name, config), class: "font-medium text-brand-600 hover:text-brand-700" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="card-pad mt-6 text-center">
      <p class="text-sm text-slate-600">No public sample configs published for <span class="font-medium"><%= @domain %></span> yet.</p>
      <%= link_to "Add the first one", new_aliro_config_path, class: "btn-primary btn-sm mt-4" %>
    </div>
  <% end %>
</div>
